{
  "name": "nest-boilerplate-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --config .prettierrc --check --ignore-unknown \"src/**/*.ts\"",
    "format:fix": "prettier --config .prettierrc --write --ignore-unknown \"src/**/*.ts\"",
    "lint": "eslint --ext .ts \"src/**/*.ts\"",
    "lint:fix": "eslint --ext .ts --fix \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "typeorm:run-migrations": "npm run typeorm migration:run -- -d ./dist/typeorm.config.js",
    "typeorm:generate-migration": "npm run typeorm -- -d ./dist/typeorm.config.js migration:generate ./src/module/database/migrations",
    "typeorm:create-migration": "npm run typeorm -- migration:create ./src/module/database/migrations",
    "typeorm:revert-migration": "npm run typeorm -- -d ./dist/typeorm.config.js migration:revert",
    "migration:create": "npm run typeorm -- migration:create ./src/module/database/migrations/$npm_config_name",
    "migration:generate": "npm run typeorm -- -d ./src/module/database/data-source.ts migration:generate ./src/module/database/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- -d ./src/module/database/data-source.ts migration:run",
    "migration:revert": "npm run typeorm -- -d ./src/module/database/data-source.ts migration:revert",
    "migration:show": "npm run typeorm -- -d ./src/module/database/data-source.ts migration:show",
    "schema:drop": "npm run typeorm -- -d ./src/module/database/data-source.ts schema:drop",
    "schema:sync": "npm run typeorm -- -d ./src/module/database/data-source.ts schema:sync",
    "seed:run": "ts-node -r tsconfig-paths/register ./src/module/database/seeds/run-seed.ts",
    "db": "pnpm run schema:drop && pnpm run migration:run && pnpm run seed:run",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@keyv/redis": "^5.1.4",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.44.0",
    "cacheable": "^2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "globals": "^16.5.0",
    "hbs": "^4.2.0",
    "helmet": "^8.1.0",
    "hygen": "^6.2.11",
    "ioredis": "^5.8.2",
    "joi": "^18.0.1",
    "keyv": "^5.5.4",
    "libphonenumber-js": "^1.12.26",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "nestjs-i18n": "^10.5.1",
    "nodemailer": "^7.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.0",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27",
    "typeorm-transactional": "^0.5.0",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.8",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "env-cmd": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">= 20"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverage": false,
    "collectCoverageFrom": [
      "**/*.(service|handler).(t|j)s"
    ],
    "coveragePathIgnorePatterns": [
      "mocks"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@module/(.*)$": "<rootDir>/module/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@apis/(.*)$": "<rootDir>/apis/$1",
      "^packageJson$": "<rootDir>/../package.json"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/dist/"
    ],
    "maxWorkers": 1,
    "detectOpenHandles": true
  },
  "packageManager": "pnpm@10.4.0"
}
